# Auto detect text files and perform LF normalization
* text=auto

# EAC writes its rip logs as UTF-16 — store them verbatim (the authentic
# artifact; the parity checker decodes via whipper_gui.parity.decode_log_bytes).
# Mark them -text so `text=auto`'s LF normalization can't corrupt the UTF-16
# (mangling the \r\x00\n\x00 sequences). The .cue sheets stay ASCII/LF text.
output_reference/**/*.log -text
