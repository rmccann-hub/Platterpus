# Byte-compiled / cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
dist/
*.egg-info/
*.egg
wheels/
# Generated at package time by build/build_appimage.sh (the build fingerprint
# baked into the wheel — see src/platterpus/build_info.py). Never committed; a
# source checkout has no stamp and reports the "source" sentinel.
src/platterpus/_build.py

# AppImage build artifacts (the build script outputs to repo root)
*.AppImage
*.AppDir/
AppDir/
build/python-appimage/.cache/
# Transient hash-verified wheelhouse (build_appimage.sh builds + removes it per
# run when requirements.lock is present); never committed. requirements.lock
# itself IS committed — it's the small text pin the wheelhouse is rebuilt from.
build/python-appimage/.wheelhouse/
# Intermediate wheel build tree from `python -m build`
build/lib/
# Locally-built wheel staged for python-appimage's PIP_FIND_LINKS
build/python-appimage/*.whl
# Note: build/python-appimage/io.github.rmccann_hub.Platterpus.png IS committed
# (the real app icon, produced by build/make_icon.py). The build script only
# generates a placeholder if that committed file is ever missing.

# Virtual environments
.venv/
venv/
env/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Claude Code: the shared, enforced .claude/settings.json IS committed (deny
# rules + the audio-guard hook). Personal/local overrides are not.
.claude/settings.local.json

# Copyrighted media — NEVER commit (CLAUDE.md Critical rule #8). This repo is
# public; committing a music file redistributes copyrighted material, even if
# it's only a temporary test file. We commit rip *logs* + per-track CRCs as the
# proof, never the audio. This is a backstop for the rule, not a substitute for
# it. (If you ever need a genuinely free/CC0/self-generated sample, override per
# file with `git add -f` — and be sure it's not a commercial track.)
*.flac
*.wav
*.mp3
*.m4a
*.aac
*.ogg
*.oga
*.opus
*.wv
*.ape
*.wma
*.aiff
*.aif
*.alac
*.dsf
*.dff

# Local cyanrip soft-fork checkout (scripts/cyanrip/README.md) - never committed.
# Root-anchored so scripts/cyanrip/ (the contribution kit) stays tracked.
/cyanrip/
